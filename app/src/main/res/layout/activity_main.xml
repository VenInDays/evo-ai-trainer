<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_50"
    tools:context=".ui.MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/navy_primary"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/app_name"
            app:titleTextColor="@color/white_pure" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ===== GENERATION DASHBOARD (Prominent) ===== -->
            <com.google.android.material.card.MaterialCardView
                style="@style/DashboardCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/navy_dark">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Generation title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CURRENT GENERATION"
                        android:textColor="@color/gray_400"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:id="@+id/tvGenerationBig"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/white_pure"
                            android:textSize="40sp"
                            android:fontFamily="sans-serif-bold" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="20dp">

                            <!-- Stagnant Generations -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/stagnant_label"
                                android:textColor="@color/gray_400"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-medium"
                                android:textAllCaps="true" />

                            <TextView
                                android:id="@+id/tvStagnant"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/warning_amber"
                                android:textSize="22sp"
                                android:fontFamily="sans-serif-bold" />
                        </LinearLayout>

                        <!-- Target indicator -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/target_label"
                                android:textColor="@color/gray_400"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-medium"
                                android:textAllCaps="true" />

                            <TextView
                                android:id="@+id/tvTargetIndicator"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="90%"
                                android:textColor="@color/emerald_success"
                                android:textSize="22sp"
                                android:fontFamily="sans-serif-bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- V3 Stats Cards Row: Global Best + Active Mut Rate -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <com.google.android.material.card.MaterialCardView
                    style="@style/DashboardCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="3dp"
                    app:cardBackgroundColor="@color/emerald_success">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/global_best_label"
                            android:textColor="@color/white_pure"
                            android:textSize="9sp"
                            android:fontFamily="sans-serif-medium"
                            android:alpha="0.8"
                            android:textAllCaps="true" />

                        <TextView
                            android:id="@+id/tvGlobalBest"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0%"
                            android:textColor="@color/white_pure"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/DashboardCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"
                    app:cardBackgroundColor="@color/slate_blue_training">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/active_mut_rate_label"
                            android:textColor="@color/white_pure"
                            android:textSize="9sp"
                            android:fontFamily="sans-serif-medium"
                            android:alpha="0.8"
                            android:textAllCaps="true" />

                        <TextView
                            android:id="@+id/tvActiveMutRate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.05"
                            android:textColor="@color/white_pure"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/DashboardCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    app:cardBackgroundColor="@color/navy_primary">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/fitness_label"
                            android:textColor="@color/white_pure"
                            android:textSize="9sp"
                            android:fontFamily="sans-serif-medium"
                            android:alpha="0.8"
                            android:textAllCaps="true" />

                        <TextView
                            android:id="@+id/tvFitness"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0"
                            android:textColor="@color/white_pure"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Dataset Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDatasetInfo"
                style="@style/CardViewStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="@color/white_pure">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDatasetStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/no_dataset"
                            android:textColor="@color/gray_600"
                            android:textSize="13sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="4dp">

                            <TextView
                                android:id="@+id/tvLikesCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/emerald_success"
                                android:textSize="12sp"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/tvNonlikesCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:textColor="@color/error_red"
                                android:textSize="12sp"
                                android:visibility="gone" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Sliders: Mutation Rate + Target Accuracy -->
            <com.google.android.material.card.MaterialCardView
                style="@style/CardViewStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="@color/white_pure">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- Mutation Rate -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/mutation_rate_label"
                            android:textColor="@color/gray_700"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tvMutationRate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.05"
                            android:textColor="@color/slate_blue_training"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold" />
                    </LinearLayout>

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderMutationRate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:stepSize="0.01"
                        android:valueFrom="0.01"
                        android:valueTo="0.50"
                        android:value="0.05"
                        app:thumbColor="@color/slate_blue_training"
                        app:trackColorActive="@color/slate_blue_training"
                        app:trackColorInactive="@color/gray_200" />

                    <!-- Target Accuracy -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/target_accuracy_label"
                            android:textColor="@color/gray_700"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tvTargetAccuracy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="90%"
                            android:textColor="@color/emerald_success"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold" />
                    </LinearLayout>

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderTargetAccuracy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:stepSize="5"
                        android:valueFrom="10"
                        android:valueTo="100"
                        android:value="90"
                        app:thumbColor="@color/emerald_success"
                        app:trackColorActive="@color/emerald_success"
                        app:trackColorInactive="@color/gray_200" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Fitness Graph -->
            <com.google.android.material.card.MaterialCardView
                style="@style/CardViewStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="@color/white_pure">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/fitness_graph_title"
                        android:textColor="@color/gray_700"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="6dp" />

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/chartFitness"
                        android:layout_width="match_parent"
                        android:layout_height="160dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== 2x5 BOTs Grid with Lineage ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/neural_bots_title"
                android:textColor="@color/gray_800"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="10dp" />

            <!-- Lineage Legend -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/badge_elite" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Legacy"
                    android:textSize="10sp"
                    android:textColor="@color/gray_600"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="12dp" />

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/badge_clone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clone"
                    android:textSize="10sp"
                    android:textColor="@color/gray_600"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="12dp" />

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/badge_reset" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reset"
                    android:textSize="10sp"
                    android:textColor="@color/gray_600"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvBots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="14dp" />

            <!-- Training Status -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTrainingStatus"
                style="@style/CardViewStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/white_pure">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvTrainingStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_ready"
                        android:textColor="@color/slate_blue_training"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium" />

                    <ProgressBar
                        android:id="@+id/progressTraining"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="5dp"
                        android:layout_marginTop="6dp"
                        android:progressDrawable="@drawable/progress_drawable"
                        android:max="100"
                        android:progress="0" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== LIVE HISTORY LOG ===== -->
            <com.google.android.material.card.MaterialCardView
                style="@style/CardViewStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="@color/navy_dark">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/history_log_title"
                        android:textColor="@color/gray_400"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="8dp" />

                    <ScrollView
                        android:id="@+id/scrollHistoryLog"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:scrollbars="vertical"
                        android:fadeScrollbars="false">

                        <TextView
                            android:id="@+id/tvHistoryLog"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/history_log_empty"
                            android:textColor="@color/gray_400"
                            android:textSize="11sp"
                            android:fontFamily="monospace"
                            android:lineSpacingExtra="3dp" />
                    </ScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- V3 Test Lab Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/test_lab_title"
                android:textColor="@color/gray_800"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="10dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardInference"
                style="@style/CardViewStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="@color/white_pure">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTestImage"
                        style="@style/ControlButton.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/test_image"
                        app:icon="@android:drawable/ic_menu_gallery"
                        app:iconGravity="textStart" />

                    <LinearLayout
                        android:id="@+id/layoutInferenceResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginTop="12dp"
                        android:visibility="gone">

                        <View
                            android:id="@+id/viewInferenceIndicator"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_marginBottom="8dp"
                            android:background="@drawable/inference_indicator" />

                        <TextView
                            android:id="@+id/tvInferenceLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="20sp"
                            android:fontFamily="sans-serif-bold"
                            android:textColor="@color/gray_800" />

                        <TextView
                            android:id="@+id/tvInferenceConfidence"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/gray_600"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Control Panel -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Controls"
                android:textColor="@color/gray_800"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnImportZip"
                    style="@style/ControlButton.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="@string/import_zip"
                    android:textSize="12sp"
                    app:icon="@android:drawable/ic_menu_upload"
                    app:iconGravity="textStart" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStartTraining"
                    style="@style/ControlButton.Primary"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="@string/start_training"
                    android:textSize="12sp"
                    app:icon="@android:drawable/ic_media_play"
                    app:iconGravity="textStart" />
            </LinearLayout>

            <!-- Model Management Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/model_management"
                android:textColor="@color/gray_800"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveModel"
                    style="@style/ControlButton.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="@string/save_model"
                    android:textSize="12sp"
                    app:icon="@android:drawable/ic_menu_save"
                    app:iconGravity="textStart" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLoadModel"
                    style="@style/ControlButton.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="@string/load_model"
                    android:textSize="12sp"
                    app:icon="@android:drawable/ic_menu_upload"
                    app:iconGravity="textStart" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExportCheckpoint"
                style="@style/ControlButton.Success"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/export_checkpoint"
                android:textSize="12sp"
                android:layout_marginBottom="6dp"
                app:icon="@android:drawable/ic_menu_save"
                app:iconGravity="textStart" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResetStorage"
                style="@style/ControlButton.Danger"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/reset_storage"
                android:textSize="12sp"
                android:layout_marginBottom="24dp"
                app:icon="@android:drawable/ic_menu_delete"
