<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardBot"
    style="@style/BotCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardBackgroundColor="@color/white_pure"
    app:strokeWidth="2dp"
    app:strokeColor="@color/gray_200">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <!-- Row 1: Indicator + Model Name + Accuracy -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:id="@+id/viewBotIndicator"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/circle_indicator"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tvBotName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Model 1 Gen 0"
                android:textColor="@color/gray_800"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvBotAccuracy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0%"
                android:textColor="@color/gray_600"
                android:textSize="12sp"
                android:fontFamily="sans-serif-bold" />
        </LinearLayout>

        <!-- Row 2: Lineage Badge -->
        <TextView
            android:id="@+id/tvLineageBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="CLONE"
            android:textSize="8sp"
            android:fontFamily="sans-serif-bold"
            android:textAllCaps="true"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:background="@drawable/badge_clone"
            android:textColor="@color/white_pure" />

        <!-- Row 3: Status + Mutation info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvBotStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ready"
                android:textColor="@color/gray_500"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/tvMutationVariance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/slate_blue_training"
                android:textSize="8sp"
                android:fontFamily="sans-serif-medium"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Row 4: Sparkline Chart (last 5 fitness scores) -->
        <com.evoai.trainer.ui.widget.SparklineView
            android:id="@+id/sparklineFitness"
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:layout_marginTop="4dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
